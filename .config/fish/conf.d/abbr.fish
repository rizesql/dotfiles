abbr cl "clear"
abbr lg "lazygit"

abbr l "eza -l --icons --git -a"
abbr ls "eza --icons --group-directories-first --color=always"
abbr ll "eza --icons --group-directories-first -l"
abbr lt "eza --tree --level=2 --icons --git"
abbr g "goto"
abbr grep 'grep --color'
abbr cwd "pwd"

abbr v "nvim"
abbr zed "zeditor"
abbr z "zeditor"

abbr .. "cd .."
abbr ... "cd ../.."
abbr .... "cd ../../.."
abbr ..... "cd ../../../.."
abbr ~ "cd ~"
abbr finder "open -R"
