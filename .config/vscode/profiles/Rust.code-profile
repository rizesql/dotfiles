{"name":"Rust","icon":"rocket","settings":"{\"settings\":\"{\\n  \\\"workbench.settings.editor\\\": \\\"json\\\",\\n\\n  // Theme\\n  \\\"workbench.colorTheme\\\": \\\"Catppuccin Mocha\\\",\\n  \\\"workbench.iconTheme\\\": \\\"moxer-icons\\\",\\n\\n  // Font\\n  \\\"editor.fontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\\",\\n  \\\"scm.inputFontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\\",\\n  \\\"terminal.integrated.fontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\\",\\n  \\\"chat.editor.fontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\\",\\n  \\\"debug.console.fontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\\",\\n  \\\"editor.codeLensFontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\\",\\n  \\\"notebook.output.fontFamily\\\": \\\"\\\\\\\"Zed Mono\\\\\\\",\\\\\\\"JetBrains Mono\\\\\\\",\\\\\\\"CaskaydiaCove Nerd Font\\\\\\\", -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif\\