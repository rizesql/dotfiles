{
  "agent_ui_font_size": 13.0,
  "buffer_line_height": {
    "custom": 1.5
  },
  "agent": {
    "dock": "left",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    },
    "default_model": {
      "provider": "ollama",
      "model": "qwen3:30b-a3b"
    },
    "model_parameters": [],
    "default_profile": "write"
  },
  "edit_predictions": {
    "mode": "subtle"
  },

  "vim_mode": true,

  "icon_theme": "Colored Zed Icons Theme Dark",
  "load_direnv": "shell_hook",
  "base_keymap": "VSCode",
  "theme": "Catppuccin Mocha",
  "ui_font_family": "Ioskeley Mono",
  "ui_font_size": 13,
  "ui_font_weight": 550,
  "buffer_font_weight": 550,
  "buffer_font_family": "Ioskeley Mono",
  "buffer_font_size": 12.5,
  "project_panel": {
    "dock": "right"
  },
  "notification_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "format_on_save": "on",
  "enable_language_server": true,
  "hover_popover_enabled": true,

  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null
    }
  },

  "lsp": {
    "rust-analyzer": {
      "enable_lsp_tasks": true,
      "binary": {
        "ignore_system_version": true
      },
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true
          },
          "closureReturnTypeHints": {
            "enable": "always"
          }
        }
      }
    },

    "nil": {
      "formatting": {
        "command": "nixfmt"
      },
      "initialization_options": {
        "checkOnSave": {
          "command": "nil",
          "filetypes": ["nix"],
          "rootPatterns": ["flake.nix"]
        }
      }
    },

    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true
        },
        "vtsls": {
          "autoUseWorkspaceTsdk": true
        }
      }
    },

    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 120
        }
      }
    },
    "pyright": {
      "settings": {
        "python.analysis": {
          "autoFormatStrings": true,
          "autoImportCompletions": true,
          "diagnostics": {
            "enabled": true,
            "useLibraryCodeForTypes": true
          },
          "generateWithTypeAnnotation": true
        }
      }
    },

    "tinymist": {
      "settings": {
        "exportPdf": "never"
      }
    },

    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "onSave": false
          }
        }
      }
    }
  },
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "formatter": "auto",
  "auto_update": true,
  "tab_size": 2,
  "wrap_guides": [90],
  "languages": {
    "TypeScript": {
      "prettier": { "allowed": false }
    },
    // "TSX": {
    //   "formatter": {
    //     "external": {
    //       "command": "./node_modules/.bin/biome",
    //       "arguments": ["format", "--write", "--stdin-file-path={buffer_path}"]
    //     }
    //   }
    // },
    // "TypeScript": {
    //   "formatter": {
    //     "external": {
    //       "command": "./node_modules/.bin/biome",
    //       "arguments": ["format", "--write", "--stdin-file-path={buffer_path}"]
    //     }
    //   }
    // },
    // "JavaScript": {
    //   "formatter": {
    //     "external": {
    //       "command": "./node_modules/.bin/biome",
    //       "arguments": ["format", "--write", "--stdin-file-path={buffer_path}"]
    //     }
    //   }
    // },
    // "Astro": {
    //   "formatter": {
    //     "external": {
    //       "command": "./node_modules/.bin/biome",
    //       "arguments": ["format", "--write", "--stdin-file-path={buffer_path}"]
    //     }
    //   }
    // },
    "Nix": {
      "formatter": {
        "external": {
          "command": "nixfmt"
        }
      },
      "language_servers": ["nixd"]
    },
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.fixAll.ruff"
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ],
      "show_edit_predictions": false
    },

    "Kotlin": {
      "language_servers": ["kotlin-lsp", "!kotlin-language-server"]
    }
  }
}
