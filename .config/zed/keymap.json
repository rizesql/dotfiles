[
  {
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-]": "workspace::ToggleRightDock",
      "ctrl-[": "workspace::ToggleLeftDock",
      "ctrl-:": "editor::ToggleInlayHints",
      "ctrl-cmd-f": "editor::Format",
      "ctrl-cmd-backspace": "editor::DeleteLine",
      "ctrl-n": "project_panel::NewFile",
      "ctrl-cmd-n": "project_panel::NewDirectory",
      "ctrl-o": "editor::OpenSelectedFilename",
      "ctrl-'": "terminal_panel::ToggleFocus",
      "ctrl-cmd-]": "pane::ActivateNextItem",
      "ctrl-cmd-[": "pane::ActivatePreviousItem"
    }
  }
]
