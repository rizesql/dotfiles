[push]
autoSetupRemote = true

[includeIf "gitdir:~/work/codestory/"]
path = ~/dotfiles/.config/git/codestory/.gitconfig

[includeIf "gitdir:~/projects/"]
path = ~/.config/git/personal/.gitconfig

[includeIf "gitdir:~/fmi/"]
path = ~/.config/git/personal/.gitconfig

[includeIf "gitdir:~/dotfiles/"]
path = ~/.config/git/personal/.gitconfig

[alias]
main-branch = !git symbolic-ref refs/remotes/origin/HEAD | cut -d '/' -f4
fomo = !git fetch origin $(git main-branch) && git rebase origin/$(git main-branch) --autostash
save = !git commit -am "commit"

[gpg "ssh"]
allowedSignersFile = ~/.config/git/allowed_signers

[core]
  editor = code --wait
  excludesfile = ~/.gitignore
  pager = delta

[interactive]
  diffFilter = delta --color-only

[include]
  path = ~/dotfiles/.config/delta/catppuccin.gitconfig

[delta]
  navigate = true  # use n and N to move between diff sections
  side-by-side = true
  dark = true      # or light = true, or omit for auto-detection
  line-numbers = true
  features = catppuccin-mocha

[merge]
  conflictstyle = zdiff3
