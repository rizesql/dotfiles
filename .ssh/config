Include /Users/rizesql/.colima/ssh_config

Include ~/.orbstack/ssh/config

Host github.com-rizesql
  HostName github.com
  IgnoreUnknown AddKeysToAgent,UseKeychain
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/git_rizesql_ssh_key
  IdentitiesOnly yes
  User git

Host github.com-codestory
  HostName github.com
  IgnoreUnknown AddKeysToAgent,UseKeychain
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/git_codestory_ssh_key
  IdentitiesOnly yes
  User git
